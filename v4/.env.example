# URL de la base de datos SQLite
DATABASE_URL="file:./prisma/dev.db"

# Secreto para firmar JWT de sesión (genera con: openssl rand -base64 32)
AUTH_SECRET="cambia_este_secreto_por_uno_real"

# Credenciales del administrador
ADMIN_EMAIL="admin@ejemplo.cl"

# Hash bcrypt del password. IMPORTANTE: Next.js expande $VAR en .env, por lo que
# los símbolos $ del hash deben escaparse con \. Genera con:
# node -e "const b=require('bcryptjs'); console.log(b.hashSync('tu_pass', 12))"
# Luego reemplaza cada $ por \$ antes de pegar aquí, sin comillas:
# Ejemplo: ADMIN_PASSWORD_HASH=\$2a\$12\$abcdef...
ADMIN_PASSWORD_HASH=

# Para desarrollo local, alternativa en texto plano (ignorado si hay HASH):
ADMIN_PASSWORD="admin123"

# Webhook opcional para notificaciones de auditoría (n8n)
N8N_WEBHOOK_URL=
