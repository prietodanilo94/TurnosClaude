# URL de la base de datos SQLite
DATABASE_URL="file:./prisma/dev.db"

# Secreto para firmar JWT de sesión (genera con: openssl rand -base64 32)
AUTH_SECRET="cambia_este_secreto_por_uno_real"

# Credenciales del administrador
ADMIN_EMAIL="admin@ejemplo.cl"
# Para producción usar ADMIN_PASSWORD_HASH (bcrypt hash del password)
# Generar con: node -e "const b=require('bcryptjs'); console.log(b.hashSync('tu_password', 12))"
ADMIN_PASSWORD_HASH=""
# Para desarrollo local puedes usar ADMIN_PASSWORD en texto plano (ignorado si ADMIN_PASSWORD_HASH está definido)
ADMIN_PASSWORD="admin123"
