generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String       @id @default(cuid())
  codigo    String       @unique
  nombre    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  teams     BranchTeam[]
  userAccess UserBranch[]
  supervisors SupervisorBranch[]
  auditLogs  AuditLog[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  nombre       String
  passwordHash String
  activo       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  branches     UserBranch[]
}

model UserBranch {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
}

// Una sucursal puede tener equipo de Ventas y/o Postventa
model BranchTeam {
  id             String     @id @default(cuid())
  branchId       String
  branch         Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  areaNegocio    String     // "ventas" | "postventa"
  categoria      String?    // "ventas_standalone" | "ventas_mall_7d" | etc.
  categoriaSetAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workers        Worker[]
  calendars      Calendar[]

  @@unique([branchId, areaNegocio])
}

model Worker {
  id           String     @id @default(cuid())
  rut          String     @unique
  nombre       String
  branchTeamId String
  branchTeam   BranchTeam @relation(fields: [branchTeamId], references: [id], onDelete: Cascade)
  activo       Boolean    @default(true)
  esVirtual    Boolean    @default(false)
  passwordHash String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  blocks       WorkerBlock[]
}

model Calendar {
  id           String     @id @default(cuid())
  branchTeamId String
  branchTeam   BranchTeam @relation(fields: [branchTeamId], references: [id], onDelete: Cascade)
  year         Int
  month        Int
  // JSON: { [slotNumber]: { [date]: { start, end } | null } }
  slotsData    String
  // JSON: { [slotNumber]: workerId | null }
  assignments  String     @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([branchTeamId, year, month])
}

model Supervisor {
  id           String             @id @default(cuid())
  nombre       String
  email        String?            @unique
  passwordHash String?
  activo       Boolean            @default(true)
  branches     SupervisorBranch[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model SupervisorBranch {
  supervisorId String
  branchId     String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([supervisorId, branchId])
}

model WorkerBlock {
  id        String   @id @default(cuid())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  motivo    String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  userRole   String?
  action     String
  entityType String
  entityId   String?
  metadata   String?
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([branchId])
}
