# ============================================
# Appwrite (para scripts de bootstrap y backend)
# ============================================
APPWRITE_ENDPOINT=https://appwrite.tu-dominio.com/v1
APPWRITE_PROJECT_ID=pon-aqui-tu-project-id
APPWRITE_API_KEY=pon-aqui-tu-api-key-con-scopes-necesarios
APPWRITE_DATABASE_ID=main

# ============================================
# Frontend (Next.js)
# ============================================
# Se exponen al navegador — usar solo valores no sensibles
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://appwrite.tu-dominio.com/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=pon-aqui-tu-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=main
NEXT_PUBLIC_OPTIMIZER_URL=http://localhost:8000

# ============================================
# Backend (FastAPI)
# ============================================
# Timeouts y defaults del optimizador
OPTIMIZER_TIME_LIMIT_SECONDS=30
OPTIMIZER_DEFAULT_NUM_PROPOSALS=3

# ============================================
# Primer admin (usado por scripts/create-first-admin.ts)
# ============================================
FIRST_ADMIN_EMAIL=tu-email@dominio.com
FIRST_ADMIN_PASSWORD=cambiar-despues-del-bootstrap
FIRST_ADMIN_NAME=Tu Nombre
